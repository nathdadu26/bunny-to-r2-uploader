# --- Bunny Stream (Stream API — library-level API key) ---
BUNNY_LIBRARY_ID=your_library_id
BUNNY_API_KEY=your_bunny_stream_api_key

# --- Bunny Edge Storage (used for the reliable zip download of processed files) ---
# Found in: Bunny dashboard -> Stream -> your library -> the linked Storage
# Zone (same name as your pull zone, e.g. vz-xxxxxxxx-xxx) -> "FTP & API Access"
# NOTE: this password is DIFFERENT from BUNNY_API_KEY above.
BUNNY_STORAGE_ZONE_NAME=vz-xxxxxxxx-xxx
BUNNY_STORAGE_PASSWORD=your_storage_zone_password
# Leave empty unless your storage zone is in a non-default region (ny/la/sg/syd/uk)
BUNNY_STORAGE_REGION=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_KEY_PREFIX=
# Public base URL for the bucket (r2.dev public URL or your custom domain) —
# required to build thumbnail/mp4/hls links saved to Mongo + posted to Telegram
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB_NAME=bunny_r2_uploader

# --- Streaming links ---
# Final link shown to users: {STREAMING_LINK_BASE}/{mapping}
STREAMING_LINK_BASE=https://mydomain.com

# --- Telegram channel posting (thumbnail + streaming link after upload) ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx
# quoted so python-dotenv parses the \n\n as an actual blank line
TELEGRAM_CAPTION_TEMPLATE="{title}\n\n{link}"

# --- Telegram bot (bot.py) — DM upload intake, needs MTProto creds too ---
# Get api_id / api_hash from https://my.telegram.org (any account, used only
# for MTProto auth — the bot still logs in with TELEGRAM_BOT_TOKEN above)
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash
# Optional: your own numeric Telegram user ID (get it from @userinfobot).
# If set, the bot DMs this ID "Bot restarted and is online" every time it
# starts — a quick way to confirm the bot process is actually alive and can
# send messages, independent of whether it's receiving/replying to yours.
# IMPORTANT: you must have sent /start to the bot at least once before —
# bots can't message users who haven't started a chat with them first.
TELEGRAM_ADMIN_CHAT_ID=

# --- App behaviour ---
MAX_CONCURRENT_JOBS=2
DELETE_LOCAL_AFTER_UPLOAD=true
DELETE_FROM_BUNNY_AFTER_SUCCESS=false
INCLUDE_ORIGINAL_IN_R2=false

# --- Health check / self-ping (health_check.py) ---
SELF_URL=
SELF_PING_INTERVAL=240
SELF_PING_ENABLED=true

PORT=8000
